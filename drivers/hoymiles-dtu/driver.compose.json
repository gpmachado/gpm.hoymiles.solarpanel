{
  "name": { "en": "Hoymiles DTU (Wi-Fi)" },
  "class": "solarpanel",
  "capabilities": [
    "measure_power",
    "meter_power",
    "measure_voltage",
    "measure_current",
    "measure_frequency",
    "measure_temperature",
    "alarm_generic",
    "measure_power.pv1",
    "measure_power.pv2",
    "measure_power.pv3",
    "measure_power.pv4",
    "measure_voltage.pv1",
    "measure_voltage.pv2",
    "measure_voltage.pv3",
    "measure_voltage.pv4",
    "measure_current.pv1",
    "measure_current.pv2",
    "measure_current.pv3",
    "measure_current.pv4"
  ],
  "capabilitiesOptions": {
    "measure_power":       { "title": { "en": "Total Power" } },
    "measure_voltage":     { "title": { "en": "AC Voltage" } },
    "measure_current":     { "title": { "en": "AC Current" } },
    "measure_power.pv1":   { "title": { "en": "Panel 1 Power" },   "units": "W" },
    "measure_power.pv2":   { "title": { "en": "Panel 2 Power" },   "units": "W" },
    "measure_power.pv3":   { "title": { "en": "Panel 3 Power" },   "units": "W" },
    "measure_power.pv4":   { "title": { "en": "Panel 4 Power" },   "units": "W" },
    "measure_voltage.pv1": { "title": { "en": "Panel 1 Voltage" }, "units": "V" },
    "measure_voltage.pv2": { "title": { "en": "Panel 2 Voltage" }, "units": "V" },
    "measure_voltage.pv3": { "title": { "en": "Panel 3 Voltage" }, "units": "V" },
    "measure_voltage.pv4": { "title": { "en": "Panel 4 Voltage" }, "units": "V" },
    "measure_current.pv1": { "title": { "en": "Panel 1 Current" }, "units": "A" },
    "measure_current.pv2": { "title": { "en": "Panel 2 Current" }, "units": "A" },
    "measure_current.pv3": { "title": { "en": "Panel 3 Current" }, "units": "A" },
    "measure_current.pv4": { "title": { "en": "Panel 4 Current" }, "units": "A" }
  },
  "energy": {
    "meterPowerExportedCapability": "meter_power"
  },
  "images": {
    "small":  "{{driverAssetsPath}}/images/small.png",
    "large":  "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  },
  "settings": [
    {
      "id": "ip",
      "type": "text",
      "label": { "en": "DTU IP Address" },
      "hint": { "en": "Local IP of your Hoymiles DTU (e.g. 192.168.1.202)" },
      "placeholder": { "en": "192.168.1.202" }
    },
    {
      "id": "polling_interval",
      "type": "number",
      "label": { "en": "Polling interval (seconds)" },
      "hint": { "en": "Minimum 35 seconds." },
      "value": 60,
      "min": 35,
      "max": 3600
    }
  ],
  "pair": [
    {
      "id": "login_credentials",
      "template": "login_credentials",
      "options": {
        "title": { "en": "Connect to Hoymiles DTU" },
        "usernameLabel": { "en": "DTU IP Address" },
        "usernamePlaceholder": { "en": "192.168.1.202" },
        "passwordLabel": { "en": " " },
        "passwordPlaceholder": { "en": " " }
      },
      "navigation": { "next": "list_devices" }
    },
    { "id": "list_devices", "template": "list_devices", "navigation": { "next": "add_devices" } },
    { "id": "add_devices", "template": "add_devices" }
  ]
}
