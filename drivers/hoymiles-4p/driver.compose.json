  "settings": [
    {
      "id": "ip",
      "type": "text",
      "label": {
        "en": "DTU IP Address"
      },
      "hint": {
        "en": "Local IP of your Hoymiles DTU (e.g. 192.168.1.202)"
      },
      "placeholder": {
        "en": "192.168.1.202"
      }
    },
    {
      "id": "polling_interval",
      "type": "number",
      "label": {
        "en": "Polling interval (seconds)"
      },
      "hint": {
        "en": "Minimum 35 seconds."
      },
      "value": 60,
      "min": 35,
      "max": 3600
    },
    {
      "id": "panel_count",
      "type": "number",
      "label": {
        "en": "Panel Count"
      },
      "hint": {
        "en": "Detected automatically during pairing."
      },
      "value": 4,
      "min": 4,
      "max": 4
    },
    {
      "id": "signal_strength",
      "type": "label",
      "label": {
        "en": "Wi-Fi Signal Strength"
      },
      "value": "—",
      "hint": {
        "en": "Updated automatically at startup"
      }
    },
    {
      "id": "wifi_ssid",
      "type": "label",
      "label": {
