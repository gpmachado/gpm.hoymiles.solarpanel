      },
      "value": "—",
      "hint": {
        "en": "Updated automatically at startup"
      }
    },
    {
      "id": "dtu_ap_ssid",
      "type": "label",
      "label": {
        "en": "DTU AP SSID"
      },
      "value": "—",
      "hint": {
        "en": "Updated automatically at startup"
      }
    },
    {
      "id": "sw_version",
      "type": "label",
      "label": {
        "en": "SW Version"
      },
      "value": "—",
      "hint": {
        "en": "Updated automatically at startup"
      }
    },
    {
      "id": "hw_version",
      "type": "label",
      "label": {
        "en": "HW Version"
      },
      "value": "—",
      "hint": {
        "en": "Updated automatically at startup"
      }
